<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#121212"
    tools:context="com.rsassistant.HealthActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Health Dashboard"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- Heart Rate Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#1E1E1E"
            android:radius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="❤️ Heart Rate"
                    android:textColor="#FF5252"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/heartRateText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- BPM"
                    android:textColor="#FFFFFF"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/heartRateStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Place finger on camera to measure"
                    android:textColor="#B0B0B0"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>

                <ProgressBar
                    android:id="@+id/heartRateProgress"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="12dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#FF5252"/>

                <Button
                    android:id="@+id/measureHeartRateBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Measure Heart Rate"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="#FF5252"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Steps Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#1E1E1E"
            android:radius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👣 Steps Today"
                    android:textColor="#4CAF50"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/stepsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 steps"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/stepsGoalText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Goal: 10,000"
                        android:textColor="#B0B0B0"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/stepsDistanceText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0 km"
                        android:textColor="#B0B0B0"
                        android:textSize="14sp"
                        android:layout_marginEnd="16dp"/>

                    <TextView
                        android:id="@+id/stepsCaloriesText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 cal"
                        android:textColor="#B0B0B0"
                        android:textSize="14sp"/>

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/stepsProgress"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="12dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#4CAF50"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Water Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#1E1E1E"
            android:radius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💧 Water Intake"
                    android:textColor="#2196F3"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/waterText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 glasses (0 ml)"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/waterGoalText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Goal: 8 glasses"
                    android:textColor="#B0B0B0"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>

                <ProgressBar
                    android:id="@+id/waterProgress"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="12dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#2196F3"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <Button
                        android:id="@+id/waterAddBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ Add Glass"
                        android:backgroundTint="#2196F3"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/waterRemoveBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="- Undo"
                        android:backgroundTint="#555555"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Eye Care Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#1E1E1E"
            android:radius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👁️ Eye Care (20-20-20)"
                    android:textColor="#9C27B0"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/eyeCareStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Eye Care Inactive"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/eyeCareBreaksText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 breaks today"
                    android:textColor="#B0B0B0"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <Button
                        android:id="@+id/eyeCareToggleBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Start Eye Care"
                        android:backgroundTint="#9C27B0"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/eyeCareBreakNowBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Break Now"
                        android:backgroundTint="#555555"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Meditation Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#1E1E1E"
            android:radius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🧘 Meditation"
                    android:textColor="#FF9800"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/meditationStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 min today • 0 sessions"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/meditationPatternText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Relaxing (4-7-8)"
                    android:textColor="#B0B0B0"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/meditationBreathsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 breaths"
                    android:textColor="#B0B0B0"
                    android:textSize="14sp"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/meditationPhaseText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#FF9800"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <Button
                        android:id="@+id/meditationStartBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Start Meditation"
                        android:backgroundTint="#FF9800"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/meditationPauseBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pause"
                        android:backgroundTint="#555555"
                        android:enabled="false"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Voice Commands Info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voice Commands"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• &quot;check heart rate&quot; - Open heart rate monitor\n• &quot;how many steps&quot; - Get step count\n• &quot;remind water&quot; - Start water reminders\n• &quot;eye break&quot; - Take an eye break\n• &quot;start meditation&quot; - Begin breathing exercise"
            android:textColor="#B0B0B0"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"/>

    </LinearLayout>

</ScrollView>
