<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RS Assistant Settings"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Voice Recognition Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Voice Recognition"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchWakeWord"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable Wake Word (Hey RS)"
            android:textColor="@color/white"
            android:layout_marginBottom="8dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchBackgroundService"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Background Voice Service"
            android:textColor="@color/white"
            android:layout_marginBottom="16dp" />

        <!-- Voice Announcer Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Voice Announcer"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchCallAnnouncement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Announce Caller Name"
            android:textColor="@color/white"
            android:layout_marginBottom="8dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchSmsReader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Read Messages Aloud"
            android:textColor="@color/white"
            android:layout_marginBottom="8dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchSilenceMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Silence Mode"
            android:textColor="@color/white"
            android:layout_marginBottom="16dp" />

        <!-- Nova Voice Settings Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nova Voice Settings"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Voice Type"
            android:textColor="@color/white"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerVoiceType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/darker_gray"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/textVoiceDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nova - Warm and friendly Indian English female voice."
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="italic"
            android:layout_marginBottom="8dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchEmotionalResponses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Emotional Voice Responses"
            android:textColor="@color/white"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnPreviewVoice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Preview Voice"
            android:layout_marginBottom="16dp" />

        <!-- Voice Settings Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Voice Settings"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/textVoiceSpeed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Speed: 0.95x"
            android:textColor="@color/white"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/seekBarVoiceSpeed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="150"
            android:progress="45"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/textVoicePitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pitch: 1.15"
            android:textColor="@color/white"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/seekBarVoicePitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="150"
            android:progress="65"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnTestVoice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Test Voice"
            android:layout_marginBottom="16dp" />

        <!-- Language Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Language"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/languageGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/radioEnglish"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="English"
                android:textColor="@color/white"
                android:checked="true" />

            <RadioButton
                android:id="@+id/radioHindi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hindi (हिंदी)"
                android:textColor="@color/white" />

            <RadioButton
                android:id="@+id/radioHinglish"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hinglish"
                android:textColor="@color/white" />

        </RadioGroup>

        <!-- Command Training Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Command Training"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnTrainCommand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Voice Command Training"
            android:layout_marginBottom="16dp" />

        <!-- Accessibility Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Accessibility"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnEnableAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable Accessibility Service"
            android:layout_marginBottom="16dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchGestureControl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable Hand Gesture Control"
            android:textColor="@color/white"
            android:layout_marginBottom="16dp" />

        <!-- Account Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Account"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/loginStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Not Logged In"
            android:textColor="@color/white"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:enabled="false" />

    </LinearLayout>

</ScrollView>
